<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AutoClicker.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AutoClicker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#6273A6"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#E60012" />
        <SolidColorBrush x:Key="SignalBrush" Color="#F68D1F" />
        <SolidColorBrush x:Key="AmberBrush" Color="#ECAB37" />
        <SolidColorBrush x:Key="NavGoldBrush" Color="#E48600" />
        <SolidColorBrush x:Key="CanvasBrush" Color="#7A8ABA" />
        <SolidColorBrush x:Key="CanvasSoftBrush" Color="#9FBEE7" />
        <SolidColorBrush x:Key="ChromeIndigoBrush" Color="#3D4F97" />
        <SolidColorBrush x:Key="MutedIndigoBrush" Color="#60619C" />
        <SolidColorBrush x:Key="PlatinumBrush" Color="#DEDEDE" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CarbonBrush" Color="#21242E" />
        <SolidColorBrush x:Key="InkBrush" Color="#21242E" />
        <SolidColorBrush x:Key="InkSoftBrush" Color="#3D4F97" />
        <SolidColorBrush x:Key="GaugeOffBrush" Color="#60619C" />
        <SolidColorBrush x:Key="HairlineBrush" Color="#5A5F8C" />
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#EEF4FF" />
        <SolidColorBrush x:Key="CarbonHoverBrush" Color="#2B3040" />

        <SolidColorBrush x:Key="FocusVisualPrimaryBrush" Color="#ECAB37" />
        <SolidColorBrush x:Key="FocusVisualSecondaryBrush" Color="#21242E" />
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#EEF4FF" />
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#21242E" />
        <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="#21242E" />
        <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="#21242E" />
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#3D4F97" />
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#E48600" />
        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#E48600" />
        <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPointerOver" Color="#21242E" />
        <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPressed" Color="#21242E" />
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2B3040" />
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#ECAB37" />
        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#9FBEE7" />
        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#21242E" />
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#9FBEE7" />
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#E48600" />

        <LinearGradientBrush x:Key="ChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A7BCEC" Offset="0" />
            <GradientStop Color="#7A8ABA" Offset="0.45" />
            <GradientStop Color="#596DAA" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="ChromePanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ChromeGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChromeIndigoBrush}" />
            <Setter Property="BorderThickness" Value="2,1,2,4" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="InsetPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PlatinumBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChromeIndigoBrush}" />
            <Setter Property="BorderThickness" Value="2,2,1,1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style x:Key="KeycapStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PlatinumBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChromeIndigoBrush}" />
            <Setter Property="BorderThickness" Value="2,2,2,5" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="CarbonDotLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="{StaticResource CanvasSoftBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeDashArray" Value="0,6" />
            <Setter Property="StrokeDashCap" Value="Round" />
            <Setter Property="Opacity" Value="0.18" />
        </Style>

        <Style x:Key="DottedDividerStyle" TargetType="Line">
            <Setter Property="Stroke" Value="{StaticResource HairlineBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeDashArray" Value="1,3" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CharacterSpacing" Value="50" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="MicroLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CharacterSpacing" Value="60" />
            <Setter Property="Foreground" Value="{StaticResource InkSoftBrush}" />
        </Style>

        <Style x:Key="KeycapLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CharacterSpacing" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkSoftBrush}" />
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLegendStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="ChromeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChromeIndigoBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="PresetChipStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChromeIndigoBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Foreground" Value="{StaticResource CanvasSoftBrush}" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Page.Resources>

    <Grid Padding="18">
        <Grid
            Width="740"
            Height="452"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border
            Width="740"
            Height="452"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource CanvasBrush}"
            BorderBrush="{StaticResource ChromeIndigoBrush}"
            BorderThickness="4"
            CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <Grid Background="{StaticResource CarbonBrush}" Padding="14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.ColumnSpan="2" IsHitTestVisible="False">
                        <Line X1="0" X2="712" Y1="6" Y2="6" Style="{StaticResource CarbonDotLineStyle}" />
                        <Line X1="0" X2="712" Y1="14" Y2="14" Style="{StaticResource CarbonDotLineStyle}" />
                        <Line X1="0" X2="712" Y1="22" Y2="22" Style="{StaticResource CarbonDotLineStyle}" />
                        <Line X1="0" X2="712" Y1="30" Y2="30" Style="{StaticResource CarbonDotLineStyle}" />
                    </Grid>

                    <Border
                        Width="206"
                        Height="32"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="3"
                        CornerRadius="999"
                        VerticalAlignment="Center">
                        <Grid>
                            <Border
                                Margin="6,4"
                                BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Opacity="0.85" />
                            <TextBlock
                                Text="AUTOCLICKER"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Arial Black"
                                FontSize="17"
                                FontWeight="Black"
                                CharacterSpacing="5"
                                Foreground="{StaticResource PrimaryBrush}" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Padding="12" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource ChromePanelStyle}">
                            <StackPanel Spacing="8">
                                <Border Background="{StaticResource CanvasBrush}" Padding="8,5" BorderBrush="{StaticResource ChromeIndigoBrush}" BorderThickness="0,1,0,2">
                                    <Grid ColumnSpacing="7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Width="10" Height="10" Fill="{StaticResource CarbonBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="STATUS" Style="{StaticResource SectionLabelStyle}" />
                                    </Grid>
                                </Border>
                                <Border
                                    x:Name="StatusPlate"
                                    Background="{StaticResource CarbonBrush}"
                                    BorderBrush="{StaticResource ChromeIndigoBrush}"
                                    BorderThickness="2,2,1,1"
                                    CornerRadius="4"
                                    Padding="12"
                                    ToolTipService.ToolTip="Shows whether the click loop is idle or actively sending clicks.">
                                    <Grid>
                                        <Grid IsHitTestVisible="False">
                                            <Line X1="0" X2="214" Y1="7" Y2="7" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="16" Y2="16" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="25" Y2="25" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="34" Y2="34" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="43" Y2="43" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="52" Y2="52" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="61" Y2="61" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="70" Y2="70" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="214" Y1="79" Y2="79" Style="{StaticResource CarbonDotLineStyle}" />
                                        </Grid>
                                        <StackPanel Spacing="8">
                                            <Grid Height="43">
                                                <TextBlock x:Name="StatusOutlineLeftText" Text="IDLE" FontFamily="Arial Black" FontSize="40" Foreground="{StaticResource ChromeIndigoBrush}" Margin="-1,0,0,0" Opacity="0" />
                                                <TextBlock x:Name="StatusOutlineRightText" Text="IDLE" FontFamily="Arial Black" FontSize="40" Foreground="{StaticResource ChromeIndigoBrush}" Margin="1,0,0,0" Opacity="0" />
                                                <TextBlock x:Name="StatusOutlineTopText" Text="IDLE" FontFamily="Arial Black" FontSize="40" Foreground="{StaticResource ChromeIndigoBrush}" Margin="0,-1,0,0" Opacity="0" />
                                                <TextBlock x:Name="StatusDropText" Text="IDLE" FontFamily="Arial Black" FontSize="40" Foreground="{StaticResource InkSoftBrush}" Margin="2,2,0,0" Opacity="0" />
                                                <TextBlock x:Name="StatusText" Text="IDLE" FontFamily="Arial Black" FontSize="40" Foreground="{StaticResource CanvasSoftBrush}" />
                                            </Grid>
                                            <TextBlock Text="CPS LOAD" Style="{StaticResource MicroLabelStyle}" Foreground="{StaticResource CanvasSoftBrush}" />
                                            <Grid ColumnSpacing="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Rectangle x:Name="SpeedSegment1" Height="8" Fill="{StaticResource GaugeOffBrush}" RadiusX="2" RadiusY="2" />
                                                <Rectangle x:Name="SpeedSegment2" Grid.Column="1" Height="8" Fill="{StaticResource GaugeOffBrush}" RadiusX="2" RadiusY="2" />
                                                <Rectangle x:Name="SpeedSegment3" Grid.Column="2" Height="8" Fill="{StaticResource GaugeOffBrush}" RadiusX="2" RadiusY="2" />
                                                <Rectangle x:Name="SpeedSegment4" Grid.Column="3" Height="8" Fill="{StaticResource GaugeOffBrush}" RadiusX="2" RadiusY="2" />
                                                <Rectangle x:Name="SpeedSegment5" Grid.Column="4" Height="8" Fill="{StaticResource GaugeOffBrush}" RadiusX="2" RadiusY="2" />
                                                <Rectangle x:Name="SpeedSegment6" Grid.Column="5" Height="8" Fill="{StaticResource GaugeOffBrush}" RadiusX="2" RadiusY="2" />
                                            </Grid>
                                            <Line X1="0" X2="214" Y1="0" Y2="0" Style="{StaticResource DottedDividerStyle}" />
                                            <TextBlock
                                                x:Name="StatusDetailText"
                                                Text="F6 starts clicking. F8 stops everything."
                                                Style="{StaticResource BodyTextStyle}"
                                                Foreground="{StaticResource SurfaceBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border
                                    Background="{StaticResource CarbonBrush}"
                                    BorderBrush="{StaticResource ChromeIndigoBrush}"
                                    BorderThickness="0,1,0,3"
                                    Padding="10"
                                    ToolTipService.ToolTip="Use global hotkeys so the game can stay focused.">
                                    <Grid>
                                        <Grid IsHitTestVisible="False">
                                            <Line X1="0" X2="222" Y1="7" Y2="7" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="222" Y1="16" Y2="16" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="222" Y1="25" Y2="25" Style="{StaticResource CarbonDotLineStyle}" />
                                            <Line X1="0" X2="222" Y1="34" Y2="34" Style="{StaticResource CarbonDotLineStyle}" />
                                        </Grid>
                                        <StackPanel Spacing="6">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Style="{StaticResource KeycapStyle}">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="TOGGLE" Style="{StaticResource KeycapLabelStyle}" VerticalAlignment="Center" />
                                                        <TextBlock x:Name="StatusToggleHotkeyText" Grid.Column="1" Text="F6" FontFamily="Arial Black" FontSize="24" Foreground="{StaticResource NavGoldBrush}" />
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Column="1" Style="{StaticResource KeycapStyle}" BorderBrush="{StaticResource PrimaryBrush}">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="STOP" Style="{StaticResource KeycapLabelStyle}" VerticalAlignment="Center" />
                                                        <TextBlock x:Name="StatusStopHotkeyText" Grid.Column="1" Text="F8" FontFamily="Arial Black" FontSize="24" Foreground="{StaticResource PrimaryBrush}" />
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <Line X1="0" X2="222" Y1="0" Y2="0" Style="{StaticResource DottedDividerStyle}" />

                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Style="{StaticResource InsetPanelStyle}" Padding="5">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="EDIT TOGGLE" Style="{StaticResource KeycapLabelStyle}" />
                                                        <ComboBox
                                                            x:Name="ToggleHotkeyBox"
                                                            Style="{StaticResource ChromeComboBoxStyle}"
                                                            AutomationProperties.Name="Start stop hotkey"
                                                            HorizontalAlignment="Stretch"
                                                            SelectionChanged="HotkeyBox_SelectionChanged"
                                                            ToolTipService.ToolTip="Global hotkey that toggles clicking." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Style="{StaticResource InsetPanelStyle}" Padding="5">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="EDIT STOP" Style="{StaticResource KeycapLabelStyle}" />
                                                        <ComboBox
                                                            x:Name="EmergencyHotkeyBox"
                                                            Style="{StaticResource ChromeComboBoxStyle}"
                                                            AutomationProperties.Name="Emergency stop hotkey"
                                                            HorizontalAlignment="Stretch"
                                                            SelectionChanged="HotkeyBox_SelectionChanged"
                                                            ToolTipService.ToolTip="Global hotkey that always stops clicking." />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <Rectangle Grid.Column="1" Fill="{StaticResource CarbonBrush}" Opacity="0.72" />

                    <StackPanel Grid.Column="2" Spacing="8">
                        <Border Style="{StaticResource ChromePanelStyle}">
                            <StackPanel Spacing="10">
                                <Border Background="{StaticResource CanvasBrush}" Padding="8,5" BorderBrush="{StaticResource ChromeIndigoBrush}" BorderThickness="0,1,0,2">
                                    <Grid ColumnSpacing="7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Width="10" Height="10" Fill="{StaticResource CarbonBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="SPEED SELECTOR" Style="{StaticResource SectionLabelStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource InsetPanelStyle}" MinHeight="248">
                                    <StackPanel Spacing="9">
                                        <Border
                                            Background="{StaticResource CarbonBrush}"
                                            BorderBrush="{StaticResource ChromeIndigoBrush}"
                                            BorderThickness="2,2,1,4"
                                            CornerRadius="3"
                                            Padding="12,9">
                                            <Grid>
                                                <Grid IsHitTestVisible="False">
                                                    <Line X1="0" X2="402" Y1="8" Y2="8" Style="{StaticResource CarbonDotLineStyle}" />
                                                    <Line X1="0" X2="402" Y1="18" Y2="18" Style="{StaticResource CarbonDotLineStyle}" />
                                                    <Line X1="0" X2="402" Y1="28" Y2="28" Style="{StaticResource CarbonDotLineStyle}" />
                                                    <Line X1="0" X2="402" Y1="38" Y2="38" Style="{StaticResource CarbonDotLineStyle}" />
                                                </Grid>
                                                <Grid RowSpacing="3">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="SELECTED RATE" Style="{StaticResource MicroLabelStyle}" Foreground="{StaticResource CanvasSoftBrush}" />
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                x:Name="SelectedCpsText"
                                                                Text="10"
                                                                FontFamily="Arial Black"
                                                                FontSize="34"
                                                                FontWeight="Black"
                                                                Foreground="{StaticResource SignalBrush}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Text="CPS"
                                                                FontFamily="Arial Black"
                                                                FontSize="18"
                                                                FontWeight="Black"
                                                                Foreground="{StaticResource CanvasSoftBrush}"
                                                                VerticalAlignment="Center" />
                                                        </Grid>
                                                    </StackPanel>
                                                    <TextBlock
                                                        x:Name="SelectedIntervalText"
                                                        Grid.Row="1"
                                                        Text="100 MS BETWEEN LEFT CLICKS"
                                                        Style="{StaticResource MicroLabelStyle}"
                                                        Foreground="{StaticResource CanvasSoftBrush}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <Border Style="{StaticResource FieldLegendStyle}">
                                            <TextBlock Text="PRESET BANK" Style="{StaticResource MicroLabelStyle}" />
                                        </Border>

                                        <Grid ColumnSpacing="6" RowSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Button x:Name="Cps1Button" Content="1" Tag="1000" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="1 click per second." />
                                            <Button x:Name="Cps2Button" Grid.Column="1" Content="2" Tag="500" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="2 clicks per second." />
                                            <Button x:Name="Cps5Button" Grid.Column="2" Content="5" Tag="200" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="5 clicks per second." />
                                            <Button x:Name="Cps10Button" Grid.Column="3" Content="10" Tag="100" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="10 clicks per second." />
                                            <Button x:Name="Cps15Button" Grid.Row="1" Content="15" Tag="67" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="About 15 clicks per second." />
                                            <Button x:Name="Cps20Button" Grid.Row="1" Grid.Column="1" Content="20" Tag="50" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="20 clicks per second." />
                                            <Button x:Name="Cps30Button" Grid.Row="1" Grid.Column="2" Content="30" Tag="33" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="About 30 clicks per second." />
                                            <Button x:Name="Cps50Button" Grid.Row="1" Grid.Column="3" Content="50" Tag="20" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="50 clicks per second." />
                                            <Button x:Name="Cps75Button" Grid.Row="2" Content="75" Tag="13" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="About 75 clicks per second." />
                                            <Button x:Name="Cps100Button" Grid.Row="2" Grid.Column="1" Content="100" Tag="10" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="100 clicks per second." />
                                            <Button x:Name="Cps150Button" Grid.Row="2" Grid.Column="2" Content="150" Tag="7" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="About 150 clicks per second." />
                                            <Button x:Name="Cps200Button" Grid.Row="2" Grid.Column="3" Content="200" Tag="5" Style="{StaticResource PresetChipStyle}" Click="CpsPresetButton_Click" ToolTipService.ToolTip="200 clicks per second. Windows or games may throttle this." />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Background="{StaticResource CarbonBrush}" Padding="12,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.ColumnSpan="2" IsHitTestVisible="False">
                        <Line X1="0" X2="712" Y1="3" Y2="3" Style="{StaticResource CarbonDotLineStyle}" />
                        <Line X1="0" X2="712" Y1="12" Y2="12" Style="{StaticResource CarbonDotLineStyle}" />
                    </Grid>
                    <TextBlock
                        Text="AUTOCLICKER ALPHA / WINDOWS ONLY"
